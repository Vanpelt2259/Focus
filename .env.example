# ── Railway environment variables ─────────────────────────────────────────────
# Copy this file to .env for local development (never commit .env to git)

# PostgreSQL connection string — Railway provides this automatically
# when you add a Postgres plugin to your Railway project.
# Leave unset for local SQLite development.
DATABASE_URL=postgresql://user:password@host:5432/focusbuddy

# Express session secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Set by Railway automatically — leave unset for local dev (defaults to 5000)
# PORT=5000

# Set NODE_ENV to production on Railway
NODE_ENV=production
